# ThinkCheck Agent Configuration
# Copy this file to .env and fill in your actual values

# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4000
DEEPSEEK_TEMPERATURE=0.1
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_TIMEOUT=30

# ThinkCheck Configuration
THINKCHECK_DEFAULT_DOMAIN=legal
THINKCHECK_HARMONY_THRESHOLD=0.7
THINKCHECK_ADVERSARIAL_THRESHOLD=0.3
THINKCHECK_ENABLE_SUGGESTIONS=true

# OCHR Configuration
OCHR_BOUNDARY_MODE=adaptive

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log

# Performance Configuration
MAX_FILE_SIZE_MB=10
BATCH_SIZE=5
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# API Service Configuration
API_HOST=0.0.0.0
API_PORT=8000
